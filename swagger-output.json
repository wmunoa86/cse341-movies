{
  "swagger": "2.0",
  "info": {
    "title": "Movies & Actors API",
    "description": "CSE 341 Week 04 - Full CRUD REST API for Movies and Actors with Google OAuth authentication.\n\n**Authentication flow:**\n1. Visit `GET /auth/google` to log in with your Google account.\n2. After login, your session cookie is set automatically.\n3. Use the Swagger UI normally — the session cookie is sent with each request.\n4. Visit `GET /auth/logout` to end your session.\n\n**Protected routes** (require login): POST, PUT, DELETE on /movies and /actors.\n**Public routes**: GET on /movies and /actors, all /auth endpoints.",
    "version": "1.0.0"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "tags": [
    {
      "name": "Auth",
      "description": "Google OAuth login, logout, and session status"
    },
    {
      "name": "Movies",
      "description": "CRUD operations for the movies collection"
    },
    {
      "name": "Actors",
      "description": "CRUD operations for the actors collection"
    }
  ],
  "schemes": [
    "http"
  ],
  "securityDefinitions": {
    "GoogleOAuth": {
      "type": "oauth2",
      "authorizationUrl": "https://accounts.google.com/o/oauth2/auth",
      "flow": "implicit",
      "scopes": {
        "profile": "Read your Google profile",
        "email": "Read your Google email address"
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/movies/": {
      "get": {
        "tags": [
          "Movies"
        ],
        "summary": "Get all movies",
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Movies"
        ],
        "summary": "Create a new movie",
        "description": "",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Movie data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string",
                  "example": "Inception"
                },
                "year": {
                  "type": "number",
                  "example": 2010
                },
                "genre": {
                  "type": "string",
                  "example": "Sci-Fi"
                },
                "director": {
                  "type": "string",
                  "example": "Christopher Nolan"
                },
                "rating": {
                  "type": "number",
                  "example": 8.8
                },
                "duration": {
                  "type": "number",
                  "example": 148
                },
                "language": {
                  "type": "string",
                  "example": "English"
                },
                "synopsis": {
                  "type": "string",
                  "example": "A thief who steals corporate secrets..."
                },
                "posterUrl": {
                  "type": "string",
                  "example": "https://example.com/poster.jpg"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "GoogleOAuth": [
              "profile",
              "email"
            ]
          }
        ]
      }
    },
